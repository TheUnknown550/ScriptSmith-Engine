# Copy this file to .env and fill in your own API keys.
# Never commit your real .env file.

# Gemini TTS (narration)
GOOGLE_API_KEY=

# Scene planning + SFX planning (MiniMax)
MINIMAX_API_KEY=
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_SCENE_MODEL=MiniMax-M3

# Image generation (Runware)
RUNWARE_API_KEY=
RUNWARE_IMAGE_MODEL=openai:gpt-image@2
RUNWARE_IMAGE_QUALITY=low
RUNWARE_IMAGE_MODERATION=auto

# Sound effect search and download (Freesound)
FREESOUND_API_KEY=
FREESOUND_CLIENT_ID=
FREESOUND_CLIENT_SECRET=
